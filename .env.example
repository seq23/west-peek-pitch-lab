# West Peek Pitch Lab local env
# Generated from config/env.registry.json
# Safe placeholders only. Replace local values as needed.
# Never commit this file.

# Runtime environment label.
# phase=phase2 scope=public_config cloudflare=plain_var
APP_ENV=development

# Canonical app base URL used by server routes and redirects.
# phase=phase2 scope=public_config cloudflare=plain_var
APP_BASE_URL=http://localhost:5173

# Public Pitch Lab URL shown or linked from public UI.
# phase=phase2 scope=public_config cloudflare=plain_var
PUBLIC_APP_URL=http://localhost:5173

# Selected LLM provider. V1 default is Gemini for lowest-cost/free-tier path.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_PROVIDER=gemini

# Gemini API key for V1 low-cost LLM path.
# phase=phase4 scope=server_secret cloudflare=secret
GEMINI_API_KEY=REPLACE_WITH_LOCAL_GEMINI_API_KEY

# Gemini model name for pitch critique and Pitch Story Card generation.
# phase=phase4 scope=server_config cloudflare=plain_var
GEMINI_MODEL=gemini-2.5-flash

# Gemini API base URL.
# phase=phase4 scope=server_config cloudflare=plain_var
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

# Maximum server-side LLM request duration before failing safely.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_TIMEOUT_MS=30000

# Maximum combined founder input characters accepted by AI endpoints.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_MAX_INPUT_CHARS=12000

# Maximum output tokens requested from Gemini for pitch critique and story-card generation.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_MAX_OUTPUT_TOKENS=2200

# Enables server-side LLM fallback routing after the primary provider fails safely.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_FALLBACK_ENABLED=true

# Lowest-cost first fallback provider after Gemini. Default fallback is OpenAI.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_FALLBACK_PROVIDER=openai

# LLM routing mode. Defaults to lowest-cost available provider order: Gemini then OpenAI fallback.
# phase=phase4 scope=server_config cloudflare=plain_var
LLM_ROUTING_MODE=lowest_cost_available

# OpenAI API key used only for server-side LLM fallback when enabled and configured.
# phase=phase4 scope=server_secret cloudflare=secret
OPENAI_API_KEY=DISABLED_UNLESS_OPENAI_FALLBACK_CONFIGURED

# OpenAI fallback model. Start with mini for quality/cost balance; test nano only after quality proof.
# phase=phase4 scope=server_config cloudflare=plain_var
OPENAI_MODEL=gpt-4.1-mini

# OpenAI API base URL for fallback provider.
# phase=phase4 scope=server_config cloudflare=plain_var
OPENAI_API_BASE_URL=https://api.openai.com

# OpenAI fallback request timeout before failing safely.
# phase=phase4 scope=server_config cloudflare=plain_var
OPENAI_TIMEOUT_MS=30000

# OpenAI fallback output token cap for cost control.
# phase=phase4 scope=server_config cloudflare=plain_var
OPENAI_MAX_OUTPUT_TOKENS=2200

# Voice provider. Phase 9D MVP uses ElevenLabs first for Scooter voice.
# phase=phase9d scope=server_config cloudflare=plain_var
VOICE_PROVIDER=elevenlabs

# ElevenLabs API key for Scooter voice and approved talking-photo/video workflows. Server-side only.
# phase=phase9d scope=server_secret cloudflare=secret
ELEVENLABS_API_KEY=REPLACE_WITH_LOCAL_ELEVENLABS_API_KEY

# ElevenLabs TTS model for approved Scooter voice rendering.
# phase=phase9d scope=server_config cloudflare=plain_var
ELEVENLABS_MODEL=eleven_multilingual_v2

# Enables Scooter voice generation for key coaching moments when provider keys are configured.
# phase=phase9d scope=server_config cloudflare=plain_var
VOICE_DYNAMIC_GENERATION_ENABLED=true

# Caches repeated voice clips where implementation supports it.
# phase=phase6 scope=server_config cloudflare=plain_var
VOICE_CACHE_ENABLED=true

# Maximum characters per voice render request.
# phase=phase6 scope=server_config cloudflare=plain_var
VOICE_MAX_CHARS=1400

# Cost guardrail for daily voice renders.
# phase=phase6 scope=server_config cloudflare=plain_var
VOICE_DAILY_MAX_RENDERS=50

# Talking-photo/video provider. Phase 9D MVP priority is ElevenLabs video/avatar first.
# phase=phase9d scope=server_config cloudflare=plain_var
AVATAR_PROVIDER=elevenlabs_video

# Avatar mode: ElevenLabs-first talking-photo/video at key coaching moments.
# phase=phase9d scope=server_config cloudflare=plain_var
AVATAR_MODE=elevenlabs_talking_photo_key_moments

# Required for intended MVP experience when provider keys/assets are configured. Disabled means degraded text/static mode.
# phase=phase9d scope=server_config cloudflare=plain_var
AVATAR_DYNAMIC_GENERATION_ENABLED=true

# False for 9D because welcome/final/share are required media moments; request-level caps still limit length.
# phase=phase9d scope=server_config cloudflare=plain_var
AVATAR_RENDER_FINAL_SUMMARY_ONLY=false

# Maximum script characters for key-moment talking-photo video render. Editorial guidance controls length; this is a safety rail, not a clipped speaking target.
# phase=phase9d scope=server_config cloudflare=plain_var
AVATAR_MAX_SCRIPT_CHARS=1200

# Maximum generated talking-photo video length per render; final summary target is 30–50 seconds with 65 second hard ceiling.
# phase=phase9d scope=server_config cloudflare=plain_var
AVATAR_MAX_VIDEO_SECONDS=65

# Cache reusable/generated avatar assets where implementation supports it.
# phase=phase6 scope=server_config cloudflare=plain_var
AVATAR_CACHE_ENABLED=true

# Must stay false until live talking-photo/video provider proof passes.
ELEVENLABS_VIDEO_ENDPOINT_CONFIRMED=false
ELEVENLABS_VIDEO_MODEL_ID=TO_BE_SET_AFTER_PROVIDER_PROOF

# Optional HeyGen fallback API key for managed avatar video generation. Server-side only.
# phase=phase9d_optional scope=server_secret cloudflare=secret
HEYGEN_API_KEY=REPLACE_WITH_LOCAL_HEYGEN_API_KEY

# Optional HeyGen fallback API base URL.
# phase=phase9d_optional scope=server_config cloudflare=plain_var
HEYGEN_API_BASE_URL=https://api.heygen.com

# Voice mode: prefer ElevenLabs audio passed into Optional HeyGen fallback instead of provider-owned generic voice.
# phase=phase9d_optional scope=server_config cloudflare=plain_var
HEYGEN_VOICE_MODE=uploaded_audio

# Optional Optional HeyGen fallback webhook secret for render callbacks.
# phase=phase9d_optional scope=server_secret cloudflare=secret
HEYGEN_WEBHOOK_SECRET=REPLACE_WITH_LOCAL_HEYGEN_WEBHOOK_SECRET

# Optional MakeUGC secondary fallback fallback API key.
# phase=phase9d_optional scope=server_secret cloudflare=secret
MAKEUGC_API_KEY=DISABLED_UNLESS_PROVIDER_SELECTED

# Optional MakeUGC secondary fallback fallback API base URL.
# phase=phase9d_optional scope=server_config cloudflare=plain_var
MAKEUGC_API_BASE_URL=disabled

# Official approved Scooter avatar source photo path.
# phase=phase9d scope=public_asset cloudflare=plain_var
SCOOTER_AVATAR_IMAGE_URL=/assets/avatar/scooter-avatar-source.png

# Approved reusable welcome talking-Scooter clip path once rendered.
# phase=phase9d scope=public_asset cloudflare=plain_var
SCOOTER_AVATAR_INTRO_VIDEO_URL=/assets/avatar/scooter-welcome.mp4

# Manifest of required AI Scooter media moments.
# phase=phase9d scope=public_asset cloudflare=plain_var
SCOOTER_AVATAR_CLIP_MANIFEST=/assets/avatar/clip-manifest.json

# Global guardrail for paid provider usage.
# phase=phase6 scope=server_config cloudflare=plain_var
COST_GUARD_ENABLED=true

# Daily maximum avatar video renders for cost control.
# phase=phase6 scope=server_config cloudflare=plain_var
AVATAR_DAILY_MAX_RENDERS=5

# Monthly maximum avatar video renders for cost control.
# phase=phase6 scope=server_config cloudflare=plain_var
AVATAR_MONTHLY_MAX_RENDERS=50

# Whether each dynamic avatar render requires operator approval.
# phase=phase6 scope=server_config cloudflare=plain_var
AVATAR_REQUIRE_OPERATOR_APPROVAL=false

# Allows founders to practice without login or capture.
# phase=phase3 scope=server_config cloudflare=plain_var
ALLOW_ANONYMOUS_PRACTICE=true

# Requires explicit consent before sharing with West Peek.
# phase=phase7 scope=server_config cloudflare=plain_var
REQUIRE_SHARE_CONSENT=true

# Requires explicit consent before email delivery.
# phase=phase8_optional scope=server_config cloudflare=plain_var
REQUIRE_EMAIL_CONSENT=true

# Must remain false. Pitch Lab submissions enter intake queue only.
# phase=phase7 scope=server_config cloudflare=plain_var
AUTO_CREATE_NETWORK_CONTACTS=false

# Requires human review for all Network OS submissions.
# phase=phase7 scope=server_config cloudflare=plain_var
HUMAN_REVIEW_REQUIRED=true

# Existing Network OS base URL.
# phase=phase7 scope=server_config cloudflare=plain_var
NETWORK_OS_BASE_URL=https://network.joinwestpeek.com

# Network OS pitch_lab intake endpoint.
# phase=phase7 scope=server_config cloudflare=plain_var
NETWORK_OS_PITCH_LAB_ENDPOINT=https://network.joinwestpeek.com/api/intake/pitch-lab

# Feature flag for sending opted-in submissions to Network OS.
# phase=phase7 scope=server_config cloudflare=plain_var
NETWORK_OS_HANDOFF_ENABLED=false

# Shared secret/signing secret for Pitch Lab to Network OS handoff.
# phase=phase7 scope=server_secret cloudflare=secret
NETWORK_OS_SHARED_SECRET=REPLACE_WITH_LOCAL_NETWORK_OS_SHARED_SECRET

# Timeout for Network OS handoff requests.
# phase=phase7 scope=server_config cloudflare=plain_var
NETWORK_OS_TIMEOUT_MS=15000

# Allowed browser origin for origin/CORS checks.
# phase=phase7 scope=server_config cloudflare=plain_var
PITCH_LAB_ALLOWED_ORIGIN=http://localhost:5173

# Enables rate limiting or abuse checks where available.
# phase=phase4 scope=server_config cloudflare=plain_var
RATE_LIMIT_ENABLED=true

# Rate-limit window length.
# phase=phase4 scope=server_config cloudflare=plain_var
RATE_LIMIT_WINDOW_SECONDS=3600

# Max requests per rate-limit window.
# phase=phase4 scope=server_config cloudflare=plain_var
RATE_LIMIT_MAX_REQUESTS=25

# Maximum founder pitch input characters.
# phase=phase3 scope=server_config cloudflare=plain_var
MAX_PITCH_INPUT_CHARS=12000

# Maximum guided questions in V1 flow.
# phase=phase3 scope=server_config cloudflare=plain_var
MAX_SESSION_QUESTIONS=8

# Optional email delivery provider. Disabled for lowest-cost V1.
# phase=phase8_optional scope=server_config cloudflare=plain_var
EMAIL_PROVIDER=disabled

# Optional email provider API key.
# phase=phase8_optional scope=server_secret cloudflare=secret
EMAIL_API_KEY=DISABLED_UNLESS_EMAIL_PROVIDER_SELECTED

# Optional email sender identity.
# phase=phase8_optional scope=server_config cloudflare=plain_var
EMAIL_FROM=Pitch Lab <pitchlab@joinwestpeek.com>

# Optional reply-to address for email delivery.
# phase=phase8_optional scope=server_config cloudflare=plain_var
EMAIL_REPLY_TO=team@joinwestpeek.com

# Feature flag for emailing Pitch Story Cards.
# phase=phase8_optional scope=server_config cloudflare=plain_var
EMAIL_CARD_ENABLED=false

# Cloudflare account ID for deployment/sync scripts. Treated as local secret.
# phase=phase10 scope=local_tooling cloudflare=none
CLOUDFLARE_ACCOUNT_ID=REPLACE_WITH_LOCAL_CLOUDFLARE_ACCOUNT_ID

# Cloudflare API token for guarded future secret sync. Server/local only.
# phase=phase10 scope=local_tooling cloudflare=none
CLOUDFLARE_API_TOKEN=REPLACE_WITH_LOCAL_CLOUDFLARE_API_TOKEN

# Cloudflare Pages/Worker project name.
# phase=phase10 scope=local_tooling cloudflare=none
CLOUDFLARE_PROJECT_NAME=west-peek-pitch-lab

# Cloudflare target environment name.
# phase=phase10 scope=local_tooling cloudflare=none
CLOUDFLARE_ENVIRONMENT=production

# Cloudflare Worker name if Worker deploy path is selected.
# phase=phase10 scope=local_tooling cloudflare=none
CLOUDFLARE_WORKER_NAME=west-peek-pitch-lab

# Canonical encrypted env vault path.
# phase=phase1 scope=local_tooling cloudflare=none
ENV_VAULT_PATH=secrets/pitch-lab.env.vault.enc

# Canonical local env path.
# phase=phase1 scope=local_tooling cloudflare=none
ENV_LOCAL_PATH=.env.local

# Current local vault encryption algorithm.
# phase=phase1 scope=local_tooling cloudflare=none
ENV_VAULT_ALGORITHM=aes-256-gcm


## Pitch Lab → Network OS profile/packet endpoints

NETWORK_OS_PROFILE_CAPTURE_ENABLED=true
NETWORK_OS_PITCH_LAB_PROFILE_ENDPOINT=https://network.example.com/api/intake/pitch-lab-profile
NETWORK_OS_PITCH_LAB_PACKET_ENDPOINT=https://network.example.com/api/intake/pitch-lab
NETWORK_OS_SHARED_SECRET=<shared-secret>
NETWORK_OS_TIMEOUT_MS=15000

Profile capture sends only founder name, email, company, and optional website. Pitch answers remain private until the Founder Story Packet is explicitly shared.

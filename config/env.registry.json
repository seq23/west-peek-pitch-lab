    },
    {
      "key": "HEYGEN_WEBHOOK_SECRET",
      "requiredPhase": "phase9d_optional",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "REPLACE_WITH_LOCAL_HEYGEN_WEBHOOK_SECRET",
      "description": "Optional Optional HeyGen fallback webhook secret for render callbacks."
    },
    {
      "key": "MAKEUGC_API_KEY",
      "requiredPhase": "phase9d_optional",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "DISABLED_UNLESS_PROVIDER_SELECTED",
      "description": "Optional MakeUGC secondary fallback fallback API key."
    },
    {
      "key": "MAKEUGC_API_BASE_URL",
      "requiredPhase": "phase9d_optional",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "disabled",
      "description": "Optional MakeUGC secondary fallback fallback API base URL."
    },
    {
      "key": "SCOOTER_AVATAR_IMAGE_URL",
      "requiredPhase": "phase9d",
      "scope": "public_asset",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed_if_public_asset",
      "placeholder": "/assets/avatar/scooter-avatar-source.png",
      "description": "Official approved Scooter avatar source photo path."
    },
    {
      "key": "SCOOTER_AVATAR_INTRO_VIDEO_URL",
      "requiredPhase": "phase9d",
      "scope": "public_asset",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed_if_public_asset",

{
  "$schema": "./env.registry.schema.json",
  "version": "phase9d-did-primary-heygen-secondary-v1",
  "repo": "west-peek-pitch-lab",
  "sourceOfTruth": "config/env.registry.json plus encrypted secrets/pitch-lab.env.vault.enc",
  "rules": {
    "localEnvFile": ".env.local",
    "encryptedVaultFile": "secrets/pitch-lab.env.vault.enc",
    "decryptedVaultFileForbidden": "secrets/pitch-lab.env.vault.json",
    "cloudflareSyncMode": "dry-run-by-default",
    "realSecretValuesInRepo": false,
    "lowestCostV1": "Cloudflare free + Gemini/OpenAI text + D-ID primary / HeyGen secondary talking avatar video for key moments.",
    "avatarPolicy": "D-ID is primary for MVP talking-avatar video. HeyGen is secondary fallback. ElevenLabs remains voice-only support and is not treated as a native talking-photo video provider.",
    "voicePolicy": "Avatar provider-owned voice is preferred for video simplicity; ElevenLabs voice remains available only for voice-only proof or explicit audio_url flows.",
    "llmPolicy": "Gemini-first server-side LLM path with OpenAI as cheapest enabled fallback; no client-side secrets; unavailable providers return honest failure without placeholder AI output.",
    "llmFallbackPolicy": "Default order is Gemini primary then OpenAI fallback when LLM_FALLBACK_ENABLED=true and LLM_ROUTING_MODE=lowest_cost_available.",
    "scooterWisdomPolicy": "Scooter Wisdom is a non-optional product invariant. The single source is content/scooter-wisdom/approved/approved-wisdom.json; there is no env layer, no mode switch, and no on/off toggle.",
    "currentImplementedPhase": "phase9d",
    "cloudflarePlanPolicy": "Default Cloudflare plan includes only non-local app runtime variables through currentImplementedPhase. Future-phase variables require --through-phase or --all. Local deploy/vault tooling variables are never pushed to the app runtime.",
    "phase6ProviderPolicy": "Superseded by Phase 9D: D-ID primary and HeyGen secondary for talking avatar video; key moments are welcome, final personalized summary, and share/close. Text-only/static is degraded mode, not intended experience.",
    "mediaIdentityPolicy": "Scooter photo and non-secret provider IDs are repo identity assets. API keys and webhook secrets remain env/vault only. Official Scooter photo lives at public/assets/avatar/scooter-avatar-source.png.",
    "phase9dProviderPolicy": "Talking AI Scooter is core. D-ID is the first provider for MVP talking-avatar video and HeyGen is secondary. Env values remain encrypted/vault-only until provided.",
    "phase9dProviderProofPolicy": "Talking-avatar MVP media is not complete until D-ID primary or HeyGen secondary returns a real queued/rendered clip for welcome/final/share moments."
  },
  "variables": [
    {
      "key": "APP_ENV",
      "requiredPhase": "phase2",
      "scope": "public_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed",
      "placeholder": "development",
      "description": "Runtime environment label.",
      "productionExample": "production"
    },
    {
      "key": "APP_BASE_URL",
      "requiredPhase": "phase2",
      "scope": "public_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed",
      "placeholder": "http://localhost:5173",
      "description": "Canonical app base URL used by server routes and redirects.",
      "productionExample": "https://pitchlab.joinwestpeek.com"
    },
    {
      "key": "PUBLIC_APP_URL",
      "requiredPhase": "phase2",
      "scope": "public_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed",
      "placeholder": "http://localhost:5173",
      "description": "Public Pitch Lab URL shown or linked from public UI.",
      "productionExample": "https://pitchlab.joinwestpeek.com"
    },
    {
      "key": "LLM_PROVIDER",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "gemini",
      "description": "Selected LLM provider. V1 default is Gemini for lowest-cost/free-tier path."
    },
    {
      "key": "GEMINI_API_KEY",
      "requiredPhase": "phase4",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "REPLACE_WITH_LOCAL_GEMINI_API_KEY",
      "description": "Gemini API key for V1 low-cost LLM path."
    },
    {
      "key": "GEMINI_MODEL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "gemini-2.5-flash",
      "description": "Gemini model name for pitch critique and Pitch Story Card generation."
    },
    {
      "key": "GEMINI_API_BASE_URL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "https://generativelanguage.googleapis.com",
      "description": "Gemini API base URL."
    },
    {
      "key": "LLM_TIMEOUT_MS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "30000",
      "description": "Maximum server-side LLM request duration before failing safely."
    },
    {
      "key": "LLM_MAX_INPUT_CHARS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "12000",
      "description": "Maximum combined founder input characters accepted by AI endpoints."
    },
    {
      "key": "LLM_MAX_OUTPUT_TOKENS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "2200",
      "description": "Cost-aware output token cap for pitch critique, Story Card, and final Scooter script generation."
    },
    {
      "key": "LLM_FALLBACK_ENABLED",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Enables server-side LLM fallback routing after the primary provider fails safely."
    },
    {
      "key": "LLM_FALLBACK_PROVIDER",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "openai",
      "description": "Lowest-cost first fallback provider after Gemini. Default fallback is OpenAI."
    },
    {
      "key": "LLM_ROUTING_MODE",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "lowest_cost_available",
      "description": "LLM routing mode. Defaults to lowest-cost available provider order: Gemini then OpenAI fallback."
    },
    {
      "key": "OPENAI_API_KEY",
      "requiredPhase": "phase4",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "DISABLED_UNLESS_OPENAI_FALLBACK_CONFIGURED",
      "description": "OpenAI API key used only for server-side LLM fallback when enabled and configured."
    },
    {
      "key": "OPENAI_MODEL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "gpt-4.1-mini",
      "description": "OpenAI fallback model. Start with mini for quality/cost balance; test nano only after quality proof."
    },
    {
      "key": "OPENAI_API_BASE_URL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "https://api.openai.com",
      "description": "OpenAI API base URL for fallback provider."
    },
    {
      "key": "OPENAI_TIMEOUT_MS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "30000",
      "description": "OpenAI fallback request timeout before failing safely."
    },
    {
      "key": "OPENAI_MAX_OUTPUT_TOKENS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "2200",
      "description": "Cost-aware output token cap for pitch critique, Story Card, and final Scooter script generation."
    },
    {
      "key": "VOICE_PROVIDER",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "uploaded_audio_primary",
      "description": "Voice path selector. Uploaded Scooter MP3 is the canonical voice sample/clone source, not a finished clip. Fish or D-ID clone generates short audio; D-ID audio_url animates that audio. ElevenLabs is fallback only."
    },
    {
      "key": "ELEVENLABS_API_KEY",
      "requiredPhase": "phase9d",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "REPLACE_WITH_LOCAL_ELEVENLABS_API_KEY",
      "description": "Fallback ElevenLabs API key for Scooter voice only if uploaded-audio/Fish dynamic voice path is unavailable. Server-side only."
    },
    {
      "key": "ELEVENLABS_MODEL",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "eleven_multilingual_v2",
      "description": "Fallback ElevenLabs TTS model. Not primary for fixed Scooter clips."
    },
    {
      "key": "VOICE_DYNAMIC_GENERATION_ENABLED",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Enables Scooter voice generation for key coaching moments when provider keys are configured."
    },
    {
      "key": "VOICE_CACHE_ENABLED",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Caches repeated voice clips where implementation supports it."
    },
    {
      "key": "VOICE_MAX_CHARS",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "1400",
      "description": "Maximum characters per voice render request. Guidance targets concise Scooter scripts without making the voice feel clipped."
    },
    {
      "key": "VOICE_DAILY_MAX_RENDERS",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "50",
      "description": "Cost guardrail for daily voice renders."
    },
    {
      "key": "AVATAR_PROVIDER",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "did",
      "description": "Talking-avatar video provider. Phase 9D default is D-ID primary."
    },
    {
      "key": "AVATAR_MODE",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "did_primary_heygen_secondary_talking_avatar",
      "description": "Avatar mode: D-ID primary and HeyGen secondary talking-avatar video at key coaching moments."
    },
    {
      "key": "AVATAR_DYNAMIC_GENERATION_ENABLED",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Required for intended MVP experience when provider keys/assets are configured. Disabled means degraded text/static mode."
    },
    {
      "key": "AVATAR_RENDER_FINAL_SUMMARY_ONLY",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",

{
  "$schema": "./env.registry.schema.json",
  "version": "phase9d-elevenlabs-first-gauntlet-v1",
  "repo": "west-peek-pitch-lab",
  "sourceOfTruth": "config/env.registry.json plus encrypted secrets/pitch-lab.env.vault.enc",
  "rules": {
    "localEnvFile": ".env.local",
    "encryptedVaultFile": "secrets/pitch-lab.env.vault.enc",
    "decryptedVaultFileForbidden": "secrets/pitch-lab.env.vault.json",
    "cloudflareSyncMode": "dry-run-by-default",
    "realSecretValuesInRepo": false,
    "lowestCostV1": "Cloudflare free + Gemini/OpenAI text + ElevenLabs-first voice and talking-photo/video for key coaching moments.",
    "avatarPolicy": "ElevenLabs first for MVP talking-photo/video at required key moments; HeyGen/MakeUGC are fallback lanes only after MVP proof; open-source/free options remain research lanes.",
    "voicePolicy": "ElevenLabs is the MVP voice provider for Scooter voice. Cheaper voice providers can be reassessed after MVP proof.",
    "llmPolicy": "Gemini-first server-side LLM path with OpenAI as cheapest enabled fallback; no client-side secrets; unavailable providers return honest failure without placeholder AI output.",
    "llmFallbackPolicy": "Default order is Gemini primary then OpenAI fallback when LLM_FALLBACK_ENABLED=true and LLM_ROUTING_MODE=lowest_cost_available.",
    "scooterWisdomPolicy": "Scooter Wisdom is a non-optional product invariant. The single source is content/scooter-wisdom/approved/approved-wisdom.json; there is no env layer, no mode switch, and no on/off toggle.",
    "currentImplementedPhase": "phase9d",
    "cloudflarePlanPolicy": "Default Cloudflare plan includes only non-local app runtime variables through currentImplementedPhase. Future-phase variables require --through-phase or --all. Local deploy/vault tooling variables are never pushed to the app runtime.",
    "phase6ProviderPolicy": "Superseded by Phase 9D: ElevenLabs first for voice + talking-photo/video; key moments are welcome, final personalized summary, and share/close. Text-only/static is degraded mode, not intended experience.",
    "mediaIdentityPolicy": "Scooter photo and non-secret provider IDs are repo identity assets. API keys and webhook secrets remain env/vault only. Official Scooter photo lives at public/assets/avatar/scooter-avatar-source.png.",
    "phase9dProviderPolicy": "Talking AI Scooter is core. ElevenLabs is first provider for MVP voice + talking-photo/video. Env values are the final 9D subset and remain encrypted/vault-only until provided.",
    "phase9dProviderProofPolicy": "ElevenLabs voice API can be tested separately from talking-photo/video. Talking-avatar MVP media is not complete until ElevenLabs/ElevenCreative or a fallback provider returns a real playable clip for welcome/final/share moments."
  },
  "variables": [
    {
      "key": "APP_ENV",
      "requiredPhase": "phase2",
      "scope": "public_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed",
      "placeholder": "development",
      "description": "Runtime environment label.",
      "productionExample": "production"
    },
    {
      "key": "APP_BASE_URL",
      "requiredPhase": "phase2",
      "scope": "public_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed",
      "placeholder": "http://localhost:5173",
      "description": "Canonical app base URL used by server routes and redirects.",
      "productionExample": "https://pitchlab.joinwestpeek.com"
    },
    {
      "key": "PUBLIC_APP_URL",
      "requiredPhase": "phase2",
      "scope": "public_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "allowed",
      "placeholder": "http://localhost:5173",
      "description": "Public Pitch Lab URL shown or linked from public UI.",
      "productionExample": "https://pitchlab.joinwestpeek.com"
    },
    {
      "key": "LLM_PROVIDER",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "gemini",
      "description": "Selected LLM provider. V1 default is Gemini for lowest-cost/free-tier path."
    },
    {
      "key": "GEMINI_API_KEY",
      "requiredPhase": "phase4",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "REPLACE_WITH_LOCAL_GEMINI_API_KEY",
      "description": "Gemini API key for V1 low-cost LLM path."
    },
    {
      "key": "GEMINI_MODEL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "gemini-2.5-flash",
      "description": "Gemini model name for pitch critique and Pitch Story Card generation."
    },
    {
      "key": "GEMINI_API_BASE_URL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "https://generativelanguage.googleapis.com",
      "description": "Gemini API base URL."
    },
    {
      "key": "LLM_TIMEOUT_MS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "30000",
      "description": "Maximum server-side LLM request duration before failing safely."
    },
    {
      "key": "LLM_MAX_INPUT_CHARS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "12000",
      "description": "Maximum combined founder input characters accepted by AI endpoints."
    },
    {
      "key": "LLM_MAX_OUTPUT_TOKENS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "2200",
      "description": "Cost-aware output token cap for pitch critique, Story Card, and final Scooter script generation."
    },
    {
      "key": "LLM_FALLBACK_ENABLED",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Enables server-side LLM fallback routing after the primary provider fails safely."
    },
    {
      "key": "LLM_FALLBACK_PROVIDER",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "openai",
      "description": "Lowest-cost first fallback provider after Gemini. Default fallback is OpenAI."
    },
    {
      "key": "LLM_ROUTING_MODE",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "lowest_cost_available",
      "description": "LLM routing mode. Defaults to lowest-cost available provider order: Gemini then OpenAI fallback."
    },
    {
      "key": "OPENAI_API_KEY",
      "requiredPhase": "phase4",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "DISABLED_UNLESS_OPENAI_FALLBACK_CONFIGURED",
      "description": "OpenAI API key used only for server-side LLM fallback when enabled and configured."
    },
    {
      "key": "OPENAI_MODEL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "gpt-4.1-mini",
      "description": "OpenAI fallback model. Start with mini for quality/cost balance; test nano only after quality proof."
    },
    {
      "key": "OPENAI_API_BASE_URL",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "https://api.openai.com",
      "description": "OpenAI API base URL for fallback provider."
    },
    {
      "key": "OPENAI_TIMEOUT_MS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "30000",
      "description": "OpenAI fallback request timeout before failing safely."
    },
    {
      "key": "OPENAI_MAX_OUTPUT_TOKENS",
      "requiredPhase": "phase4",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "2200",
      "description": "Cost-aware output token cap for pitch critique, Story Card, and final Scooter script generation."
    },
    {
      "key": "VOICE_PROVIDER",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "elevenlabs",
      "description": "Voice provider. Phase 9D MVP uses ElevenLabs first for Scooter voice."
    },
    {
      "key": "ELEVENLABS_API_KEY",
      "requiredPhase": "phase9d",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "REPLACE_WITH_LOCAL_ELEVENLABS_API_KEY",
      "description": "ElevenLabs API key for Scooter voice and approved talking-photo/video workflows. Server-side only."
    },
    {
      "key": "ELEVENLABS_MODEL",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "eleven_multilingual_v2",
      "description": "ElevenLabs TTS model for approved Scooter voice rendering."
    },
    {
      "key": "VOICE_DYNAMIC_GENERATION_ENABLED",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Enables Scooter voice generation for key coaching moments when provider keys are configured."
    },
    {
      "key": "VOICE_CACHE_ENABLED",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Caches repeated voice clips where implementation supports it."
    },
    {
      "key": "VOICE_MAX_CHARS",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "1400",
      "description": "Maximum characters per voice render request. Guidance targets concise Scooter scripts without making the voice feel clipped."
    },
    {
      "key": "VOICE_DAILY_MAX_RENDERS",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "50",
      "description": "Cost guardrail for daily voice renders."
    },
    {
      "key": "AVATAR_PROVIDER",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "elevenlabs_video",
      "description": "Talking-photo/video provider. Phase 9D MVP priority is ElevenLabs video/avatar first."
    },
    {
      "key": "AVATAR_MODE",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "elevenlabs_talking_photo_key_moments",
      "description": "Avatar mode: ElevenLabs-first talking-photo/video at key coaching moments."
    },
    {
      "key": "AVATAR_DYNAMIC_GENERATION_ENABLED",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Required for intended MVP experience when provider keys/assets are configured. Disabled means degraded text/static mode."
    },
    {
      "key": "AVATAR_RENDER_FINAL_SUMMARY_ONLY",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "false",
      "description": "False for 9D because welcome/final/share are required media moments; request-level caps still limit length."
    },
    {
      "key": "AVATAR_MAX_SCRIPT_CHARS",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "1200",
      "description": "Maximum script characters for key-moment talking-photo video render. Duration guidance controls cost; this is the safety rail."
    },
    {
      "key": "AVATAR_MAX_VIDEO_SECONDS",
      "requiredPhase": "phase9d",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "65",
      "description": "Maximum generated talking-photo video length per render; final summary target is 30-50 seconds with a 65 second hard ceiling."
    },
    {
      "key": "AVATAR_CACHE_ENABLED",
      "requiredPhase": "phase6",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "true",
      "description": "Cache reusable/generated avatar assets where implementation supports it."
    },
    {
      "key": "ELEVENLABS_VIDEO_ENDPOINT_CONFIRMED",
      "requiredPhase": "phase9d_proof",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "false",
      "description": "Must remain false until the actual ElevenLabs talking-photo/lip-sync API endpoint, model/workflow, and asset IDs have been live-proven. Prevents false avatar_configured status."
    },
    {
      "key": "ELEVENLABS_VIDEO_MODEL_ID",
      "requiredPhase": "phase9d_proof",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "TO_BE_SET_AFTER_PROVIDER_PROOF",
      "description": "Optional provider model/workflow identifier for ElevenLabs/ElevenCreative talking-photo proof once a real endpoint is confirmed."
    },
    {
      "key": "HEYGEN_API_KEY",
      "requiredPhase": "phase9d_optional",
      "scope": "server_secret",
      "cloudflareBinding": "secret",
      "clientExposure": "forbidden",
      "placeholder": "REPLACE_WITH_LOCAL_HEYGEN_API_KEY",
      "description": "Optional HeyGen fallback API key for managed avatar video generation. Server-side only."
    },
    {
      "key": "HEYGEN_API_BASE_URL",
      "requiredPhase": "phase9d_optional",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "https://api.heygen.com",
      "description": "Optional HeyGen fallback API base URL."
    },
    {
      "key": "HEYGEN_VOICE_MODE",
      "requiredPhase": "phase9d_optional",
      "scope": "server_config",
      "cloudflareBinding": "plain_var",
      "clientExposure": "forbidden",
      "placeholder": "uploaded_audio",

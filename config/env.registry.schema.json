{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "West Peek Pitch Lab Env Registry",
  "type": "object",
  "required": [
    "version",
    "repo",
    "rules",
    "variables"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "repo": {
      "const": "west-peek-pitch-lab"
    },
    "sourceOfTruth": {
      "type": "string"
    },
    "rules": {
      "type": "object"
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "requiredPhase",
          "scope",
          "cloudflareBinding",
          "clientExposure",
          "placeholder",
          "description"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "requiredPhase": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "cloudflareBinding": {
            "enum": [
              "plain_var",
              "secret",
              "none"
            ]
          },
          "clientExposure": {
            "type": "string"
          },
          "placeholder": {
            "type": "string"
          },
          "productionExample": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
